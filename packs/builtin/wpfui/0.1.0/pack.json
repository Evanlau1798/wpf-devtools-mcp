  "nugetPackages": [
    {
      "id": "WPF-UI",
      "versionRange": "[4.3.0,5.0.0)"
    }
  ],
  "xmlNamespaces": {
    "ui": "http://schemas.lepo.co/wpfui/2022/xaml"
  },
  "resourceSetup": {
    "applicationMergedDictionaries": [
      "<ui:ThemesDictionary Theme=\"Dark\" />",
      "<ui:ControlsDictionary />"
    ]
  },
  "themeTokens": {
    "cornerRadius.control": "8",
    "spacing.medium": "12",
    "spacing.small": "8"
  },
  "preview": {
    "namespaceUri": "http://schemas.lepo.co/wpfui/2022/xaml",
    "clrNamespace": "Wpf.Ui.Controls",
    "types": {
      "AutoSuggestBox": {
        "baseKind": "contentControl",
        "contentProperty": "PlaceholderText",
        "properties": { "PlaceholderText": "string" }
      },
      "Button": {
        "baseKind": "button",
        "properties": { "Appearance": "string", "Command": "object", "Icon": "object" }
      },
      "Card": {
        "baseKind": "stackPanel",
        "contentProperty": "Footer",
        "properties": { "Footer": "object" }
      },
      "DataGrid": {
        "baseKind": "itemsControl",
        "properties": { "Columns": "objectCollection" }
      },
      "FluentWindow": {
        "baseKind": "window",
        "properties": {}
      },
      "NavigationView": {
        "baseKind": "itemsControl",
        "contentProperty": "ContentOverlay",
        "properties": {
          "AutoSuggestBox": "object",
          "ContentOverlay": "object",
          "FooterMenuItems": "objectCollection",
          "IsBackButtonVisible": "string",
          "IsFooterSeparatorVisible": "boolean",
          "IsPaneToggleVisible": "boolean",
          "IsTopSeparatorVisible": "boolean",
          "MenuItems": "objectCollection",
          "OpenPaneLength": "double",
          "PaneDisplayMode": "string"
        }
      },
        "NavigationViewItem": {
          "baseKind": "button",
        "properties": {
          "Command": "object",
          "CommandParameter": "object",
          "Icon": "object",
          "IsActive": "boolean",
          "IsExpanded": "boolean",
          "MenuItems": "objectCollection",
          "TargetPageTag": "string"
        }
      },
      "NavigationViewItemSeparator": { "baseKind": "control", "properties": {} },
      "NumberBox": {
        "baseKind": "control",
        "properties": { "Maximum": "double", "Minimum": "double", "SmallChange": "double", "Value": "double" }
      },
      "ProgressRing": {
        "baseKind": "frameworkElement",
        "properties": { "IsIndeterminate": "boolean", "Progress": "double" }
      },
      "SymbolIcon": {
        "baseKind": "contentControl",
        "contentProperty": "Symbol",
        "properties": { "Symbol": "string" }
      },
      "TabView": {
        "baseKind": "tabControl",
        "properties": {}
      },
      "TabViewItem": {
        "baseKind": "tabItem",
        "properties": {}
      },
      "TextBlock": {
        "baseKind": "contentControl",
        "contentProperty": "Text",
        "properties": { "Appearance": "string", "Text": "string", "TextAlignment": "string", "TextWrapping": "string" }
      },
      "TitleBar": {
        "baseKind": "control",
        "properties": { "Icon": "object", "Title": "string", "TrailingContent": "object" }
      },
      "ToggleSwitch": {
        "baseKind": "toggleButton",
        "properties": { "LabelPosition": "string", "OffContent": "string", "OnContent": "string" }
      }
    }
  },
  "blocks": [
    "wpfui.card",
    "wpfui.navigationView",
    "wpfui.navigationViewDemo",
    "wpfui.navigationViewItem",
    "wpfui.navigationViewItemSeparator",
    "wpfui.numberBox",
    "wpfui.progressRing",
    "wpfui.tabView",
    "wpfui.tabViewItem",
    "wpfui.fluentWindow",
    "wpfui.dataGrid",
    "wpfui.button",
    "wpfui.titleBar",
    "wpfui.toggleSwitch",
