<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <!-- Exclude MCP Server entry point (top-level statements, requires real STDIO server) -->
          <ExcludeByFile>**/Program.cs</ExcludeByFile>
          <!-- Exclude ToolRegistrar files (configuration code, only executed when MCP Server starts) -->
          <ExcludeByFile>**/ToolRegistrar*.cs</ExcludeByFile>
          <!-- Exclude classes marked with [ExcludeFromCodeCoverage] -->
          <ExcludeByAttribute>ExcludeFromCodeCoverage</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
