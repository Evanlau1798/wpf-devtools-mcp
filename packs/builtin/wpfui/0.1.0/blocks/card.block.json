{
  "schemaVersion": "wpfdevtools.ui-block.v1",
  "kind": "wpfui.card",
  "displayName": "Card",
  "description": "Semantic WPF UI Card block.",
  "category": "container",
  "properties": {
    "horizontalContentAlignment": {
      "default": "Stretch",
      "enum": ["Left", "Center", "Right", "Stretch"],
      "type": "string"
    },
    "margin": { "default": "0", "format": "thickness", "type": "string" },
    "maxWidth": { "default": 1000000, "minimum": 0, "type": "number" },
    "minHeight": { "default": 0, "minimum": 0, "type": "number" },
    "padding": { "default": "16", "format": "thickness", "type": "string" },
    "verticalContentAlignment": {
      "default": "Stretch",
      "enum": ["Top", "Center", "Bottom", "Stretch"],
      "type": "string"
    }
  },
  "slots": {
    "actions": {
      "allowedKinds": [
        "wpfui.button"
      ]
    },
    "content": {
      "allowedKinds": ["*"]
    },
    "header": {
      "allowedKinds": [
        "core.text",
        "wpfui.textBlock"
      ]
    }
  },
  "renderer": {
    "xamlTemplate": "renderers/xaml/card.xaml.sbn"
  },
  "validation": {},
  "sourceHints": [
    {
      "path": "src/Wpf.Ui/Controls/Card/Card.cs",
      "usage": "semantic extraction"
    }
  ]
}
