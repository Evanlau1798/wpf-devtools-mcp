<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|Win32">
      <Configuration>Debug</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|ARM64">
      <Configuration>Debug</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|ARM64">
      <Configuration>Release</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{A1B2C3D4-5678-9012-ABCD-EF0123456789}</ProjectGuid>
    <RootNamespace>WpfDevToolsBootstrapper</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup>
    <PreferredPlatformToolset Condition="'$(PreferredPlatformToolset)' == '' and Exists('$(VCTargetsPath)\Platforms\Win32\PlatformToolsets\v145\Toolset.props')">v145</PreferredPlatformToolset>
    <PreferredPlatformToolset Condition="'$(PreferredPlatformToolset)' == ''">v143</PreferredPlatformToolset>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Debug'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset Condition="'$(PlatformToolset)' == ''">$(PreferredPlatformToolset)</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Label="Configuration" Condition="'$(Configuration)'=='Release'">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset Condition="'$(PlatformToolset)' == ''">$(PreferredPlatformToolset)</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup>
    <RepoRootDir>$(MSBuildProjectDirectory)\..\..\</RepoRootDir>
    <OutDir>$(RepoRootDir)artifacts\bootstrapper\$(Configuration)\$(Platform)\</OutDir>
    <IntDir>$(Configuration)\$(Platform)\</IntDir>
    <NetHostAssetsDir>$(RepoRootDir)artifacts\dotnet-host\$(Platform)\native</NetHostAssetsDir>
    <NetFxSdkLibraryDir Condition="'$(NetFxSdkLibraryDir)' == '' and '$(NETFXKitsDir)' != '' and '$(Platform)'=='Win32'">$(NETFXKitsDir)Lib\um\x86</NetFxSdkLibraryDir>
    <NetFxSdkLibraryDir Condition="'$(NetFxSdkLibraryDir)' == '' and '$(NETFXKitsDir)' != '' and '$(Platform)'=='x64'">$(NETFXKitsDir)Lib\um\x64</NetFxSdkLibraryDir>
    <NetFxSdkLibraryDir Condition="'$(NetFxSdkLibraryDir)' == '' and '$(NETFXKitsDir)' != '' and '$(Platform)'=='ARM64' and Exists('$(NETFXKitsDir)Lib\um\arm64\mscoree.lib')">$(NETFXKitsDir)Lib\um\arm64</NetFxSdkLibraryDir>
    <NetFxSdkLibraryDir Condition="'$(NetFxSdkLibraryDir)' == '' and '$(NETFXKitsDir)' != '' and '$(Platform)'=='ARM64'">$(NETFXKitsDir)Lib\um\arm</NetFxSdkLibraryDir>
    <BootstrapperFileVersion Condition="'$(BootstrapperFileVersion)' == ''">1,0,0,0</BootstrapperFileVersion>
    <BootstrapperProductVersion Condition="'$(BootstrapperProductVersion)' == ''">1,0,0,0</BootstrapperProductVersion>
    <BootstrapperFileVersionString Condition="'$(BootstrapperFileVersionString)' == ''">1.0.0.0</BootstrapperFileVersionString>
    <BootstrapperProductVersionString Condition="'$(BootstrapperProductVersionString)' == ''">1.0.0-beta.1</BootstrapperProductVersionString>
    <TargetName Condition="'$(Platform)'=='Win32'">WpfDevTools.Bootstrapper.x86</TargetName>
    <TargetName Condition="'$(Platform)'=='x64'">WpfDevTools.Bootstrapper.x64</TargetName>
    <TargetName Condition="'$(Platform)'=='ARM64'">WpfDevTools.Bootstrapper.arm64</TargetName>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <ConformanceMode>true</ConformanceMode>
      <PreprocessorDefinitions>WIN32_LEAN_AND_MEAN;NOMINMAX;_CRT_SECURE_NO_WARNINGS;NETHOST_USE_AS_STATIC;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <DebugInformationFormat Condition="'$(BootstrapperDebugInformationFormat)' != ''">$(BootstrapperDebugInformationFormat)</DebugInformationFormat>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <AdditionalIncludeDirectories>$(NetHostAssetsDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation Condition="'$(BootstrapperGenerateDebugInformation)' == ''">true</GenerateDebugInformation>
      <GenerateDebugInformation Condition="'$(BootstrapperGenerateDebugInformation)' != ''">$(BootstrapperGenerateDebugInformation)</GenerateDebugInformation>
      <ProgramDatabaseFile Condition="'$(BootstrapperGenerateDebugInformation)' == 'false'"></ProgramDatabaseFile>
      <ModuleDefinitionFile>exports.def</ModuleDefinitionFile>
      <AdditionalLibraryDirectories>$(NetHostAssetsDir);$(NetFxSdkLibraryDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>libnethost.lib;Crypt32.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalOptions>/ignore:4099 %(AdditionalOptions)</AdditionalOptions>
    </Link>
    <ResourceCompile>
      <PreprocessorDefinitions>WPFDEVTOOLS_BOOTSTRAPPER_FILE_VERSION=$(BootstrapperFileVersion);WPFDEVTOOLS_BOOTSTRAPPER_PRODUCT_VERSION=$(BootstrapperProductVersion);WPFDEVTOOLS_BOOTSTRAPPER_FILE_VERSION_STRING=&quot;$(BootstrapperFileVersionString)&quot;;WPFDEVTOOLS_BOOTSTRAPPER_PRODUCT_VERSION_STRING=&quot;$(BootstrapperProductVersionString)&quot;;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ResourceCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="dllmain.cpp" />
    <ClCompile Include="bootstrap_entry.cpp" />
    <ClCompile Include="clr_hosting.cpp" />
    <ClCompile Include="coreclr_hosting.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="secure_memory.h" />
    <ClInclude Include="exit_codes.h" />
    <ClInclude Include="clr_hosting.h" />
    <ClInclude Include="coreclr_hosting.h" />
  </ItemGroup>
  <ItemGroup>
    <ResourceCompile Include="bootstrapper.rc" />
  </ItemGroup>
  <ItemGroup>
    <None Include="exports.def" />
  </ItemGroup>
  <Target Name="PrepareNetHostAssets" BeforeTargets="ClCompile">
    <Exec Command="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\resolve_nethost_assets.ps1&quot; -Platform &quot;$(Platform)&quot; -OutputDir &quot;$(NetHostAssetsDir)&quot;" />
  </Target>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
