{
  "schemaVersion": "wpfdevtools.ui-recipe.v1",
  "id": "wpfui.shellWithNavigation",
  "displayName": "WPF UI Navigation Shell",
  "description": "A customizable WPF UI shell with command-bound navigation destinations, a command-bound primary action, and application-specific content. Implement the returned behavior integration contract before treating the generated shell as functional.",
  "customizationGuidance": [
    "Invent the application's information architecture and domain language before selecting or renaming navigation destinations.",
    "Use this recipe as a starting fragment, then change its content hierarchy and interactions to fit the application rather than preserving the sample topology."
  ],
  "packId": "wpfui",
  "requiredPacks": [
    {
      "id": "core",
      "version": "0.1.0",
      "required": true,
      "role": "layout-pack"
    },
    {
      "id": "wpfui",
      "version": "0.1.0",
      "required": true,
      "role": "primary"
    }
  ],
  "inputs": {
    "contentBody": {
      "description": "Application-specific summary shown in the primary content card.",
      "default": "Review current operations and choose a workflow from navigation.",
      "type": "string"
    },
    "contentHeading": {
      "description": "Application-specific heading shown in the primary content card.",
      "default": "Overview",
      "type": "string"
    },
    "navigationCommand": {
      "description": "Simple ICommand binding used by every navigation destination. The command receives the stable destination tag as its parameter.",
      "default": "{Binding NavigateCommand}",
      "type": "binding"
    },
    "navigationItem1Tag": {
      "description": "Stable navigation tag for the first destination.",
      "default": "overview",
      "type": "string"
    },
    "navigationItem1Text": {
      "description": "Visible label for the first navigation destination.",
      "default": "Home",
      "type": "string"
    },
    "navigationItem2Tag": {
      "description": "Stable navigation tag for the second destination.",
      "default": "workspace",
      "type": "string"
    },
    "navigationItem2Text": {
      "description": "Visible label for the second navigation destination.",
      "default": "Workspace",
      "type": "string"
    },
    "navigationItem3Tag": {
      "description": "Stable navigation tag for the third destination.",
      "default": "activity",
      "type": "string"
    },
    "navigationItem3Text": {
      "description": "Visible label for the third navigation destination.",
      "default": "Activity",
      "type": "string"
    },
    "navigationItem4Tag": {
      "description": "Stable navigation tag for the fourth destination.",
      "default": "reports",
      "type": "string"
    },
    "navigationItem4Text": {
      "description": "Visible label for the fourth navigation destination.",
      "default": "Reports",
      "type": "string"
    },
    "primaryActionCommand": {
      "description": "Simple ICommand binding used by the primary content action.",
      "default": "{Binding PrimaryActionCommand}",
      "type": "binding"
    },
    "primaryActionText": {
      "description": "Visible label for the primary content action.",
      "default": "Open workspace",
      "type": "string"
    },
    "settingsText": {
      "description": "Visible label for the settings footer destination.",
      "default": "Settings",
      "type": "string"
    },
    "title": {
      "description": "Application and title-bar title.",
      "default": "WPF UI Application",
      "type": "string"
    }
  },
  "expandsTo": {
    "kind": "wpfui.fluentWindow",
    "properties": {
      "height": 760,
      "title": "{{title}}",
      "width": 1280
    },
    "slots": {
      "content": [
        {
          "kind": "wpfui.navigationView",
          "slots": {
            "content": [
              {
                "kind": "wpfui.card",
                "slots": {
                  "actions": [
                    {
                      "kind": "wpfui.button",
                      "properties": {
                        "command": "{{primaryActionCommand}}",
                        "text": "{{primaryActionText}}"
                      }
                    }
                  ],
                  "content": [
                    {
                      "kind": "core.stack",
                      "slots": {
                        "children": [
                          {
                            "kind": "wpfui.textBlock",
                            "properties": {
                              "text": "{{contentBody}}"
                            }
                          }
                        ]
                      }
                    }
                  ],
                  "header": [
                    {
                      "kind": "wpfui.textBlock",
                      "properties": {
                        "text": "{{contentHeading}}"
                      }
                    }
                  ]
                }
              }
            ],
            "footer": [
              {
                "kind": "wpfui.navigationViewItem",
                "properties": {
                  "command": "{{navigationCommand}}",
                  "commandParameter": "settings",
                  "targetPageTag": "settings"
                },
                "slots": {
                  "content": [
                    {
                      "kind": "core.text",
                      "properties": {
                        "text": "{{settingsText}}"
                      }
                    }
                  ],
                  "icon": [
                    {
                      "kind": "wpfui.symbolIcon",
                      "properties": {
                        "symbol": "Settings24"
                      }
                    }
                  ]
                }
              }
            ],
            "items": [
              {
                "kind": "wpfui.navigationViewItem",
                "properties": {
                  "command": "{{navigationCommand}}",
                  "commandParameter": "{{navigationItem1Tag}}",
                  "isActive": true,
                  "targetPageTag": "{{navigationItem1Tag}}"
                },
                "slots": {
                  "content": [
                    {
                      "kind": "core.text",
                      "properties": {
                        "text": "{{navigationItem1Text}}"
                      }
                    }
                  ],
                  "icon": [
                    {
                      "kind": "wpfui.symbolIcon",
                      "properties": {
                        "symbol": "Home24"
                      }
                    }
                  ]
                }
              },
              {
                "kind": "wpfui.navigationViewItem",
                "properties": {
                  "command": "{{navigationCommand}}",
                  "commandParameter": "{{navigationItem2Tag}}",
                  "targetPageTag": "{{navigationItem2Tag}}"
                },
                "slots": {
                  "content": [
                    {
                      "kind": "core.text",
                      "properties": {
                        "text": "{{navigationItem2Text}}"
                      }
                    }
                  ],
                  "icon": [
                    {
                      "kind": "wpfui.symbolIcon",
                      "properties": {
                        "symbol": "List24"
                      }
                    }
                  ]
                }
              },
              {
                "kind": "wpfui.navigationViewItem",
                "properties": {
                  "command": "{{navigationCommand}}",
                  "commandParameter": "{{navigationItem3Tag}}",
                  "targetPageTag": "{{navigationItem3Tag}}"
                },
                "slots": {
                  "content": [
                    {
                      "kind": "core.text",
                      "properties": {
                        "text": "{{navigationItem3Text}}"
                      }
                    }
                  ],
                  "icon": [
                    {
                      "kind": "wpfui.symbolIcon",
                      "properties": {
                        "symbol": "Table24"
                      }
                    }
                  ]
                }
              },
              {
                "kind": "wpfui.navigationViewItem",
                "properties": {
                  "command": "{{navigationCommand}}",
                  "commandParameter": "{{navigationItem4Tag}}",
                  "targetPageTag": "{{navigationItem4Tag}}"
                },
                "slots": {
                  "content": [
                    {
                      "kind": "core.text",
                      "properties": {
                        "text": "{{navigationItem4Text}}"
                      }
                    }
                  ],
                  "icon": [
                    {
                      "kind": "wpfui.symbolIcon",
                      "properties": {
                        "symbol": "Info24"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ],
      "titleBar": [
        {
          "kind": "wpfui.titleBar",
          "properties": {
            "title": "{{title}}"
          }
        }
      ]
    }
  }
}
