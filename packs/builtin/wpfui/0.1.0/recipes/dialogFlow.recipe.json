{
  "schemaVersion": "wpfdevtools.ui-recipe.v1",
  "id": "wpfui.dialogFlow",
  "displayName": "Dialog Flow Starter",
  "description": "A WPF UI ContentDialog with text content and a primary action.",
  "packId": "wpfui",
  "requiredPacks": [
    {
      "id": "core",
      "version": "0.1.0",
      "required": true,
      "role": "optional"
    },
    {
      "id": "wpfui",
      "version": "0.1.0",
      "required": true,
      "role": "primary"
    }
  ],
  "inputs": {
    "message": {
      "default": "Continue with this action?",
      "type": "string"
    },
    "primaryAction": {
      "default": "Continue",
      "type": "string"
    },
    "title": {
      "default": "Confirm",
      "type": "string"
    }
  },
  "expandsTo": {
    "kind": "wpfui.contentDialog",
    "properties": {
      "title": "{{title}}"
    },
    "slots": {
      "actions": [
        {
          "kind": "wpfui.button",
          "properties": {
            "text": "{{primaryAction}}"
          }
        }
      ],
      "content": [
        {
          "kind": "core.text",
          "properties": {
            "text": "{{message}}"
          }
        }
      ]
    }
  }
}
