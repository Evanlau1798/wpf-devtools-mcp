<ui:FluentWindow Title="{{title}}" Width="{{width}}" Height="{{height}}" MinWidth="900" MinHeight="600">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="0">
      {{slot.titleBar}}
    </Grid>
    <Grid Grid.Row="1">
      {{slot.content}}
    </Grid>
  </Grid>
</ui:FluentWindow>
