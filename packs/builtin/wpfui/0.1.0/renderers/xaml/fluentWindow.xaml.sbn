<ui:FluentWindow Title="{{title}}" Width="{{width}}" Height="{{height}}" MinWidth="{{minWidth}}" MinHeight="{{minHeight}}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <ContentControl Grid.Row="0" HorizontalContentAlignment="Stretch">
      {{slot.titleBar}}
    </ContentControl>
    <Border Grid.Row="1" Padding="{{contentPadding}}" MaxWidth="{{contentMaxWidth}}" HorizontalAlignment="Stretch">
      {{slot.content}}
    </Border>
  </Grid>
</ui:FluentWindow>
