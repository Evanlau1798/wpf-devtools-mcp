{
  "schemaVersion": "wpfdevtools.ui-block.v1",
  "kind": "mahapps.window",
  "displayName": "Metro Window",
  "description": "Minimal real MahApps MetroWindow subclass proof.",
  "category": "window",
  "properties": {
    "title": { "type": "string", "required": true, "default": "MahApps app" },
    "width": { "type": "number", "default": 880, "minimum": 320 },
    "height": { "type": "number", "default": 560, "minimum": 240 }
  },
  "slots": {
    "content": { "allowedKinds": ["*"] }
  },
  "renderer": {
    "xamlTemplate": "renderers/xaml/window.xaml.sbn",
    "codeBehindBaseType": "MahApps.Metro.Controls.MetroWindow"
  },
  "sourceHints": [
    { "path": "src/MahApps.Metro/Controls/MetroWindow.cs", "usage": "public custom Window subclass" }
  ]
}
