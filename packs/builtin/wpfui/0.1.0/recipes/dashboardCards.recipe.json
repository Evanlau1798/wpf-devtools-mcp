{
  "schemaVersion": "wpfdevtools.ui-recipe.v1",
  "id": "wpfui.dashboardCards",
  "displayName": "Dashboard Card Starter",
  "description": "A WPF UI card with header, body text, and a primary action.",
  "packId": "wpfui",
  "requiredPacks": [
    {
      "id": "wpfui",
      "version": "0.1.0",
      "required": true,
      "role": "primary"
    }
  ],
  "inputs": {
    "actionText": {
      "default": "Open",
      "type": "string"
    },
    "body": {
      "default": "Summarize the current state.",
      "type": "string"
    },
    "heading": {
      "default": "Overview",
      "type": "string"
    }
  },
  "expandsTo": {
    "kind": "wpfui.card",
    "slots": {
      "actions": [
        {
          "kind": "wpfui.button",
          "properties": {
            "text": "{{actionText}}"
          }
        }
      ],
      "content": [
        {
          "kind": "text",
          "properties": {
            "value": "{{body}}"
          }
        }
      ],
      "header": [
        {
          "kind": "wpfui.textBlock",
          "properties": {
            "text": "{{heading}}"
          }
        }
      ]
    }
  }
}
