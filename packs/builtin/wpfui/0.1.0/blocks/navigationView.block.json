{
  "schemaVersion": "wpfdevtools.ui-block.v1",
  "kind": "wpfui.navigationView",
  "displayName": "Navigation View",
  "description": "Semantic WPF UI Navigation View block.",
  "category": "navigation",
  "properties": {
    "paneDisplayMode": {
      "description": "Navigation pane placement mode supported by the WPF UI control.",
      "default": "Left",
      "enum": ["Left", "LeftMinimal", "LeftFluent", "Top", "Bottom"],
      "required": false,
      "type": "string"
    }
  },
  "slots": {
    "content": {
      "description": "Primary page content displayed in the navigation content surface.",
      "allowedKinds": [
        "core.text",
        "core.stack",
        "core.template",
        "wpfui.card",
        "wpfui.navigationViewDemo"
      ]
    },
    "footer": {
      "description": "Persistent navigation actions rendered at the bottom of the pane.",
      "allowedKinds": [
        "wpfui.navigationViewItem",
        "wpfui.button"
      ]
    },
    "items": {
      "description": "Ordered primary navigation entries and separators.",
      "allowedKinds": [
        "wpfui.navigationViewItem",
        "wpfui.navigationViewItemSeparator"
      ]
    }
  },
  "renderer": {
    "xamlTemplate": "renderers/xaml/navigationView.xaml.sbn"
  },
  "validation": {},
  "sourceHints": [
    {
      "path": "src/Wpf.Ui/Controls/NavigationView/NavigationView.Base.cs",
      "usage": "semantic extraction"
    }
  ]
}
