{
  "schemaVersion": "wpfdevtools.ui-recipe.v1",
  "id": "wpfui.tabbedSettings",
  "displayName": "Tabbed Settings Starter",
  "description": "A WPF UI TabView with two settings tabs.",
  "packId": "wpfui",
  "requiredPacks": [
    {
      "id": "core",
      "version": "0.1.0",
      "required": true,
      "role": "layout-pack"
    },
    {
      "id": "wpfui",
      "version": "0.1.0",
      "required": true,
      "role": "primary"
    }
  ],
  "inputs": {
    "generalTitle": {
      "default": "General",
      "type": "string"
    },
    "securityTitle": {
      "default": "Security",
      "type": "string"
    }
  },
  "expandsTo": {
    "kind": "wpfui.tabView",
    "slots": {
      "items": [
        {
          "kind": "wpfui.tabViewItem",
          "slots": {
            "content": [
              {
                "kind": "wpfui.card"
              }
            ],
            "header": [
              {
                "kind": "core.text",
                "properties": {
                  "text": "{{generalTitle}}"
                }
              }
            ]
          }
        },
        {
          "kind": "wpfui.tabViewItem",
          "slots": {
            "content": [
              {
                "kind": "wpfui.card"
              }
            ],
            "header": [
              {
                "kind": "core.text",
                "properties": {
                  "text": "{{securityTitle}}"
                }
              }
            ]
          }
        }
      ]
    }
  }
}
