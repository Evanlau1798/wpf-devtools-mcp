{
  "schemaVersion": "wpfdevtools.ui-block.v1",
  "kind": "core.text",
  "displayName": "Text",
  "description": "Displays native WPF text that inherits the surrounding theme foreground unless an explicit foreground is provided.",
  "category": "display",
  "properties": {
    "text": { "type": "string", "default": "Text" },
    "fontSize": { "type": "number", "default": 14, "minimum": 1 },
    "fontWeight": { "type": "string", "default": "Normal", "enum": ["Thin", "ExtraLight", "Light", "Normal", "Medium", "SemiBold", "Bold", "ExtraBold", "Black"] },
    "textWrapping": { "type": "string", "default": "Wrap", "enum": ["NoWrap", "Wrap", "WrapWithOverflow"] },
    "textAlignment": { "type": "string", "default": "Left", "enum": ["Left", "Center", "Right", "Justify"] },
    "margin": { "type": "string", "default": "0", "format": "thickness" },
    "foreground": { "type": "string" }
  },
  "slots": {},
  "renderer": { "xamlTemplate": "renderers/xaml/text.xaml.sbn" },
  "sourceHints": [{ "path": "System.Windows.Controls.TextBlock", "usage": "native WPF text" }]
}
