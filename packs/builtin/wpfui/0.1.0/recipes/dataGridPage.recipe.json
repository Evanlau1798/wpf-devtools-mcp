{
  "schemaVersion": "wpfdevtools.ui-recipe.v1",
  "id": "wpfui.dataGridPage",
  "displayName": "Data Grid Page Starter",
  "description": "A WPF UI DataGrid fragment with binding and empty-state text.",
  "packId": "wpfui",
  "requiredPacks": [
    {
      "id": "core",
      "version": "0.1.0",
      "required": true,
      "role": "layout-pack"
    },
    {
      "id": "wpfui",
      "version": "0.1.0",
      "required": true,
      "role": "primary"
    }
  ],
  "inputs": {
    "emptyText": {
      "default": "No rows",
      "type": "string"
    },
    "itemsSource": {
      "default": "{Binding Items}",
      "type": "binding"
    }
  },
  "expandsTo": {
    "kind": "wpfui.dataGrid",
    "properties": {
      "itemsSource": "{{itemsSource}}"
    },
    "slots": {
      "columns": [
        {
          "kind": "core.template"
        }
      ],
      "emptyState": [
        {
          "kind": "wpfui.textBlock",
          "properties": {
            "text": "{{emptyText}}"
          }
        }
      ]
    }
  }
}
