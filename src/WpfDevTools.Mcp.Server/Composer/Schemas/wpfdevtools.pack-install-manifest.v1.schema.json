{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wpfdevtools.pack-install-manifest.v1.schema.json",
  "title": "WPF DevTools Pack Install Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "scope",
    "path",
    "enabled"
  ],
  "properties": {
    "schemaVersion": {
      "const": "wpfdevtools.pack-install-manifest.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "version": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": [
        "project-local",
        "user-global",
        "composer-builtin"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "x-source": {
    "repository": "https://github.com/Evanlau1798/wpf-devtools-extension-pack-creator",
    "ref": "master",
    "commit": "9b7b88fa092870994d0121cdc7b436ab633591a4"
  }
}
