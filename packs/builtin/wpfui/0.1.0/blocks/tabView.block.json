{
  "schemaVersion": "wpfdevtools.ui-block.v1",
  "kind": "wpfui.tabView",
  "displayName": "Tab View",
  "description": "Themed WPF UI Tab View that explicitly applies the upstream TabControl style to its semantic subclass.",
  "category": "navigation",
  "properties": {
    "selectedIndex": {
      "description": "Zero-based index of the initially selected tab.",
      "default": 0,
      "integer": true,
      "required": false,
      "type": "number"
    }
  },
  "slots": {
    "items": {
      "description": "Ordered tab items displayed by the tab view.",
      "allowedKinds": [
        "wpfui.tabViewItem"
      ]
    }
  },
  "renderer": {
    "xamlTemplate": "renderers/xaml/tabView.xaml.sbn"
  },
  "validation": {},
  "sourceHints": [
    {
      "path": "src/Wpf.Ui/Controls/TabView/TabView.cs",
      "usage": "semantic extraction"
    }
  ]
}
