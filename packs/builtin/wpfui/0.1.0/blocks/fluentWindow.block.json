{
  "schemaVersion": "wpfdevtools.ui-block.v1",
  "kind": "wpfui.fluentWindow",
  "displayName": "Fluent Window",
  "description": "Semantic WPF UI Fluent Window block.",
  "category": "window",
  "properties": {
    "height": {
      "default": 802,
      "required": false,
      "type": "number"
    },
    "title": {
      "default": "Window",
      "required": false,
      "type": "string"
    },
    "width": {
      "default": 1450,
      "required": false,
      "type": "number"
    }
  },
  "slots": {
    "content": {
      "allowedKinds": [
        "wpfui.navigationView",
        "wpfui.card",
        "stack",
        "template"
      ]
    },
    "titleBar": {
      "allowedKinds": [
        "wpfui.titleBar"
      ]
    }
  },
  "renderer": {
    "xamlTemplate": "renderers/xaml/fluentWindow.xaml.sbn"
  },
  "validation": {},
  "sourceHints": [
    {
      "path": "src/Wpf.Ui/Controls/FluentWindow/FluentWindow.cs",
      "usage": "semantic extraction"
    }
  ]
}
