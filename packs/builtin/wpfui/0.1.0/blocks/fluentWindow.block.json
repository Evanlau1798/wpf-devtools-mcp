{
  "schemaVersion": "wpfdevtools.ui-block.v1",
  "kind": "wpfui.fluentWindow",
  "displayName": "Fluent Window",
  "description": "Semantic WPF UI Fluent Window block.",
  "category": "window",
  "properties": {
    "height": {
      "default": 802,
      "required": false,
      "type": "number"
    },
    "contentMaxWidth": { "default": 1000000, "minimum": 0, "type": "number" },
    "contentPadding": { "default": "0", "format": "thickness", "type": "string" },
    "minHeight": { "default": 600, "minimum": 0, "type": "number" },
    "minWidth": { "default": 900, "minimum": 0, "type": "number" },
    "title": {
      "default": "Window",
      "required": false,
      "type": "string"
    },
    "width": {
      "default": 1450,
      "required": false,
      "type": "number"
    }
  },
  "slots": {
    "content": {
      "allowedKinds": ["*"]
    },
    "titleBar": {
      "allowedKinds": [
        "wpfui.titleBar"
      ]
    }
  },
  "renderer": {
    "xamlTemplate": "renderers/xaml/fluentWindow.xaml.sbn"
  },
  "validation": {},
  "sourceHints": [
    {
      "path": "src/Wpf.Ui/Controls/FluentWindow/FluentWindow.cs",
      "usage": "semantic extraction"
    }
  ]
}
